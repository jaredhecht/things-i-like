# Copy to .env.local and fill in. Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://auth.thingsilike.app
NEXT_PUBLIC_SUPABASE_ANON_KEY=
OWNER_USER_ID=

# Public site origin (optional; used for canonical URLs in some places).
NEXT_PUBLIC_SITE_URL=https://thingsilike.app

# Server-only (required for account deletion and cron). Supabase → Project Settings → API → service_role.
# Do not use in client code or NEXT_PUBLIC_* vars.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for cron routes (Authorization: Bearer <value>). e.g. daily digest, Loops audience sync.
# CRON_SECRET=

# Resend email sending (used by admin digest and Happening Things weekly email).
# Set RESEND_DISABLED=1 to stop all Resend sends and audience sync without removing API keys.
# RESEND_DISABLED=1
# RESEND_API_KEY=
# ADMIN_DIGEST_FROM=
# Optional dedicated sender for the weekly digest; falls back to ADMIN_DIGEST_FROM.
# WEEKLY_DIGEST_FROM=
# Optional Resend Topic id for the curated Things of the Week newsletter.
# RESEND_THINGS_OF_WEEK_TOPIC_ID=
# Optional Resend segment id for broadcast sends; if omitted and exactly one segment exists, scripts will use that.
# RESEND_BROADCAST_SEGMENT_ID=
# Optional dedicated unsubscribe signing secret; falls back to CRON_SECRET.
# WEEKLY_DIGEST_UNSUBSCRIBE_SECRET=

# Server-only: Google Places (Autocomplete, Details, Photo). Used by /api/places/* with the user’s JWT.
GOOGLE_MAPS_API_KEY=

# Loops audience sync (GET /api/cron/loops-sync-audience with Authorization: Bearer CRON_SECRET).
# LOOPS_API_KEY=
# Optional: comma-separated mailing list ids from GET ?listsOnly=1 on the same route.
# LOOPS_MAILING_LIST_IDS=
# Optional: cap Loops API calls per run (re-run to continue).
# LOOPS_SYNC_MAX_PER_RUN=

# Happening Things weekly — GET /api/cron/happening-things-weekly (Bearer CRON_SECRET).
# Sends personalized server-rendered emails via Resend. Run supabase/weekly-digest-email.sql once.
# HAPPENING_THINGS_DISABLED=1
# HAPPENING_THINGS_MAX_RECIPIENTS=10

# Optional: base URL for `npm run loops:lists` / `npm run loops:sync` (default http://localhost:3000).
# LOOPS_SYNC_BASE=https://thingsilike.app
