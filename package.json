{
  "name": "things-i-like",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "email:preview-loops": "mjml email/loops-things-of-the-week/index.mjml -o email/loops-things-of-the-week/preview.html",
    "email:serve-preview": "npm run email:preview-loops && npx --yes serve email/loops-things-of-the-week -l 4173",
    "email:zip-loops": "cd email/loops-things-of-the-week && rm -f things-of-the-week-loops.zip && zip -r things-of-the-week-loops.zip index.mjml img -x 'img/.gitkeep' -x '*.DS_Store'",
    "email:zip-happening-loops": "cd email/happening-things-weekly && rm -f happening-things-loops.zip && zip happening-things-loops.zip index.mjml",
    "email:normalize-hero-images": "node email/loops-things-of-the-week/normalize-hero-images.cjs",
    "loops:lists": "node --env-file=.env.local scripts/loops-audience.mjs lists",
    "loops:sync": "node --env-file=.env.local scripts/loops-audience.mjs sync",
    "loops:happening-bootstrap": "node --env-file=.env.local scripts/loops-bootstrap-happening-event.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.9.4",
    "sanitize-html": "^2.17.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "mjml": "^4.15.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
