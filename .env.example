# Copy to .env.local and fill in. Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site origin (optional; used for canonical URLs in some places).
NEXT_PUBLIC_SITE_URL=

# Server-only (required for account deletion and cron). Supabase → Project Settings → API → service_role.
# Do not use in client code or NEXT_PUBLIC_* vars.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for cron routes (Authorization: Bearer <value>). e.g. daily digest, Loops audience sync.
# CRON_SECRET=

# Server-only: Google Places (Autocomplete, Details, Photo). Used by /api/places/* with the user’s JWT.
GOOGLE_MAPS_API_KEY=

# Loops audience sync (GET /api/cron/loops-sync-audience with Authorization: Bearer CRON_SECRET).
# LOOPS_API_KEY=
# Optional: comma-separated mailing list ids from GET ?listsOnly=1 on the same route.
# LOOPS_MAILING_LIST_IDS=
# Optional: cap Loops API calls per run (re-run to continue).
# LOOPS_SYNC_MAX_PER_RUN=

# Optional: base URL for `npm run loops:lists` / `npm run loops:sync` (default http://localhost:3000).
# LOOPS_SYNC_BASE=https://thingsilike.app
